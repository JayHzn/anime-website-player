{
  "manifest_version": 3,
  "name": "AnimeHub Source",
  "version": "2.0.2",
  "description": "Fournit les sources anime et drama pour AnimeHub",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://anime-sama.to/*",
    "https://french-anime.com/*",
    "https://vostfree.ws/*",
    "https://*.vidmoly.to/*",
    "https://*.vidmoly.biz/*",
    "https://*.voe.sx/*",
    "https://*.f16px.com/*",
    "https://*.streamtape.com/*",
    "https://*.sendvid.com/*",
    "https://*.sibnet.ru/*",
    "https://raw.githubusercontent.com/*",
    "https://api.jikan.moe/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://anime-website-player.onrender.com/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://localhost:5173/*",
        "http://localhost:8080/*",
        "http://localhost:8000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "icons/icon48.png"
  }
}
